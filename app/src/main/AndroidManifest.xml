<?xml version="1.0" encoding="utf-8"?>
<!--
    YTSR - Your TV Screen Recorder
    Developer: YOUNUS
    NO android.permission.INTERNET — zero-network privacy by design.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── PERMISSIONS (no INTERNET) ───────────────────────────────── -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"  android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- ── ANDROID TV FEATURES ─────────────────────────────────────── -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback"    android:required="true"  />
    <uses-feature android:name="android.hardware.microphone"  android:required="false" />

    <!-- ── APPLICATION ─────────────────────────────────────────────── -->
    <application
        android:allowBackup="false"
        android:banner="@drawable/app_banner"
        android:icon="@drawable/app_banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.YTSR"
        tools:targetApi="31">

        <!-- Main Leanback launcher Activity -->
        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|screenSize"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Transparent trampoline Activity — shows MediaProjection consent dialog.
            Launched by AccessibilityService (which cannot call startActivityForResult itself).
        -->
        <activity
            android:name=".MediaProjectionRequestActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!--
            Foreground Service — foregroundServiceType="mediaProjection" is required
            by Android 10+ to capture the screen while the app is in the background.
        -->
        <service
            android:name=".RecordingService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"
            android:stopWithTask="false" />

        <!--
            Accessibility Service — intercepts remote [0][0] and [1][1] key presses
            globally, even when Peo TV or any other app is in the foreground.
        -->
        <service
            android:name=".YTSRAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
