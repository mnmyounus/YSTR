<?xml version="1.0" encoding="utf-8"?>
<!--
    YTSR Accessibility Service Configuration
    ─────────────────────────────────────────
    canRequestFilterKeyEvents="true"  ← XML declaration (required)
    flagRequestFilterKeyEvents        ← also set programmatically in onServiceConnected()

    Together these allow this service to intercept and optionally CONSUME
    remote control KeyEvents before they reach the foreground app (e.g. Peo TV).
    Only confirmed double-presses of [0] and [1] are consumed; all other keys
    are passed through transparently.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRequestFilterKeyEvents|flagReportViewIds"
    android:canRequestFilterKeyEvents="true"
    android:canRetrieveWindowContent="false"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity=".MainActivity" />
